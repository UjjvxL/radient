# ═══════════════════════════════════════
# Radient — Environment Variables
# ═══════════════════════════════════════

# JioSaavn API (your local or Vercel deployment)
JIOSAAVN_API_URL=http://localhost:3001

# Spotify OAuth (get from https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_REDIRECT_URI=http://localhost:3000/auth/spotify/callback

# Token encryption key (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
TOKEN_ENCRYPTION_KEY=

# Redis (for BullMQ queues)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Server
PORT=3000
